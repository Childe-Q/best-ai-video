  "nuggets": [
    {
      "text": "Runway Free starts with 125 one-time credits, which the pricing page maps to about 25 seconds of Gen-4 Turbo generation.",
      "theme": "usage",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
      "capturedAt": "2026-03-21T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "The Free plan keeps a watermark and does not include Gen-4 video access.",
      "theme": "export",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
      "capturedAt": "2026-03-21T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Runway's security standards help article says uploaded assets are private by default and that SOC 2 Type II coverage applies across plans.",
      "theme": "security",
      "sourceUrl": "https://help.runwayml.com/hc/en-us/articles/24300377879827-Understanding-Runway-s-security-and-privacy-standards",
      "sourceType": "help",
      "capturedAt": "2026-04-10T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Runway's data-security page says customer content is protected with TLS 1.2 or higher in transit and AES-256 encryption at rest.",
      "theme": "security",
      "sourceUrl": "https://runwayml.com/data-security",
      "sourceType": "docs",
      "capturedAt": "2026-04-10T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Runway's Enterprise Features help article lists SSO, organization and workspace controls, brand kits, enterprise analytics, and the ability to disable external link sharing.",
      "theme": "enterprise",
      "sourceUrl": "https://help.runwayml.com/hc/en-us/articles/48625698573075-Enterprise-Features",
      "sourceType": "help",
      "capturedAt": "2026-04-10T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Runway also describes Characters as a real-time video agent API for building custom conversational characters with control over voice, personality, knowledge, and actions.",
      "theme": "workflow",
      "sourceUrl": "https://runwayml.com/",
      "sourceType": "features",
      "capturedAt": "2026-04-10T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Runway Standard includes 625 monthly credits, which the pricing page maps to 25 seconds of Gen-4.5 or 125 seconds of Gen-4 Turbo generation.",
      "theme": "usage",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
      "capturedAt": "2026-03-21T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Standard plan access includes Aleph, Gen-4.5, Gen-4, Act-Two, Veo 3.1, and Veo 3.",
      "theme": "models",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
      "capturedAt": "2026-03-21T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Standard supports up to 5 users per workspace and 100GB of asset storage.",
      "theme": "team",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
      "capturedAt": "2026-03-21T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Pro expands the workspace limit to 10 users and 500GB of asset storage.",
      "theme": "team",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
      "capturedAt": "2026-03-21T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Paid plans include watermark removal, upscale resolution, and access to all video models.",
      "theme": "export",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
      "capturedAt": "2026-03-21T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Unlimited adds Explore Mode with unlimited generations at a relaxed rate.",
      "theme": "usage",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
      "capturedAt": "2026-03-21T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Enterprise advertises single sign-on, advanced security and compliance, and workspace analytics.",
      "theme": "security",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
      "capturedAt": "2026-03-21T12:00:00+08:00",
      "confidence": "high"
    },
    {
      "text": "Enterprise also lists configurable organization spaces and integration with internal tools.",
      "theme": "integrations",
      "sourceUrl": "https://runwayml.com/pricing",
      "sourceType": "pricing",
